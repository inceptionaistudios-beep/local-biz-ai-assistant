# Safe default: no API key or network call is required.
LOCAL_BIZ_PROVIDER=local
LOCAL_BIZ_PROFILE=examples/business_profile.json
LOCAL_BIZ_LOG_LEVEL=INFO
LOCAL_BIZ_REQUEST_TIMEOUT=15

# Optional OpenAI-compatible provider. Leave blank in local mode.
# Keep real values only in your untracked .env file.
LOCAL_BIZ_API_KEY=
LOCAL_BIZ_API_BASE_URL=https://provider.example/v1
LOCAL_BIZ_MODEL=example-model
